{% extends "layouts/admin.twig" %}

{% block content %}
    <div>
        <strong>Всего предметов:</strong> <span id="total-subjects">{{ total_subjects }}</span>
    </div>
    <p>
        <button id="create-subject-btn">+ Добавить предмет</button>
    </p>

    <!-- Поиск -->
    <p>
        <input type="text" id="search-subject" placeholder="Поиск по названию..." style="padding: 5px; width: 300px;">
        <button id="reset-search-btn" style="display: none;">Сбросить</button>
    </p>

    <table border="1" cellpadding="8" cellspacing="0" style="border-collapse: collapse; width: 100%;">
        <thead>
            <tr>
                <th>ID</th>
                <th>Код</th>
                <th>Название</th>
                <th>Кратко</th>
                <th>Часы</th>
                <th>Семестр</th>
                <th>Активен</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody id="subjects-table-body">
            {% for subject in subjects %}
            <tr data-id="{{ subject.id }}">
                <td>{{ subject.id }}</td>
                <td>{{ subject.code|default('—') }}</td>
                <td>
                    <strong>{{ subject.name }}</strong>
                    {% if subject.description %}
                        <br><small>{{ subject.description|slice(0, 80) }}...</small>
                    {% endif %}
                </td>
                <td>{{ subject.short_name|default('—') }}</td>
                <td>{{ subject.hours }}</td>
                <td>{{ subject.semester }}</td>
                <td>{{ subject.is_active ? 'Да' : 'Нет' }}</td>
                <td>
                    <button class="edit-subject-btn" data-id="{{ subject.id }}">Редактировать</button>
                    <button class="delete-subject-btn" data-id="{{ subject.id }}">Удалить</button>
                </td>
            </tr>
            {% else %}
            <tr>
                <td colspan="8">Предметы не найдены</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>

    <!-- Модальное окно создания предмета -->
    <div id="create-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5);">
        <div style="background: white; width: 600px; margin: 50px auto; padding: 20px;">
            <h3>Добавление предмета</h3>
            <form id="create-subject-form">
                <label>Код предмета:</label><br>
                <input type="text" id="create-subject-code" style="width: 100%;"><br><br>

                <label>Название: <span style="color: red;">*</span></label><br>
                <input type="text" id="create-subject-name" required style="width: 100%;"><br><br>

                <label>Краткое название:</label><br>
                <input type="text" id="create-subject-short-name" style="width: 100%;"><br><br>

                <label>Описание:</label><br>
                <textarea id="create-subject-description" rows="3" style="width: 100%;"></textarea><br><br>

                <div style="display: flex; gap: 20px;">
                    <div style="flex: 1;">
                        <label>Часы:</label><br>
                        <input type="number" id="create-subject-hours" value="0" style="width: 100%;">
                    </div>
                    <div style="flex: 1;">
                        <label>Семестр:</label><br>
                        <select id="create-subject-semester" style="width: 100%;">
                            <option value="1">1 семестр</option>
                            <option value="2">2 семестр</option>
                            <option value="3">3 семестр</option>
                            <option value="4">4 семестр</option>
                            <option value="5">5 семестр</option>
                            <option value="6">6 семестр</option>
                            <option value="7">7 семестр</option>
                            <option value="8">8 семестр</option>
                        </select>
                    </div>
                </div>
                <br>

                <label>Специальность:</label><br>
                <input type="text" id="create-subject-specialty" style="width: 100%;"><br><br>

                <label>
                    <input type="checkbox" id="create-subject-active" checked> Активен
                </label>
                <br><br>

                <button type="button" id="close-create-modal">Отмена</button>
                <button type="submit">Создать</button>
            </form>
        </div>
    </div>

    <!-- Модальное окно редактирования предмета -->
    <div id="edit-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5);">
        <div style="background: white; width: 600px; margin: 50px auto; padding: 20px;">
            <h3>Редактирование предмета</h3>
            <form id="edit-subject-form">
                <input type="hidden" id="edit-subject-id">

                <label>Код предмета:</label><br>
                <input type="text" id="edit-subject-code" style="width: 100%;"><br><br>

                <label>Название: <span style="color: red;">*</span></label><br>
                <input type="text" id="edit-subject-name" required style="width: 100%;"><br><br>

                <label>Краткое название:</label><br>
                <input type="text" id="edit-subject-short-name" style="width: 100%;"><br><br>

                <label>Описание:</label><br>
                <textarea id="edit-subject-description" rows="3" style="width: 100%;"></textarea><br><br>

                <div style="display: flex; gap: 20px;">
                    <div style="flex: 1;">
                        <label>Часы:</label><br>
                        <input type="number" id="edit-subject-hours" value="0" style="width: 100%;">
                    </div>
                    <div style="flex: 1;">
                        <label>Семестр:</label><br>
                        <select id="edit-subject-semester" style="width: 100%;">
                            <option value="1">1 семестр</option>
                            <option value="2">2 семестр</option>
                            <option value="3">3 семестр</option>
                            <option value="4">4 семестр</option>
                            <option value="5">5 семестр</option>
                            <option value="6">6 семестр</option>
                            <option value="7">7 семестр</option>
                            <option value="8">8 семестр</option>
                        </select>
                    </div>
                </div>
                <br>

                <label>Специальность:</label><br>
                <input type="text" id="edit-subject-specialty" style="width: 100%;"><br><br>

                <label>
                    <input type="checkbox" id="edit-subject-active"> Активен
                </label>
                <br><br>

                <button type="button" id="close-edit-modal">Отмена</button>
                <button type="submit">Сохранить</button>
            </form>
        </div>
    </div>

    <!-- Модальное окно удаления -->
    <div id="delete-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5);">
        <div style="background: white; width: 400px; margin: 50px auto; padding: 20px;">
            <h3>Подтверждение удаления</h3>
            <p>Вы уверены, что хотите удалить предмет <strong id="delete-item-name"></strong>?</p>
            <button id="close-delete-modal">Отмена</button>
            <button id="confirm-delete">Удалить</button>
        </div>
    </div>
{% endblock %}