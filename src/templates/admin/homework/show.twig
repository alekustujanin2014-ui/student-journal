{% extends "layouts/admin.twig" %}

{% block content %}
    <!-- Фильтр и поиск -->
    <div style="margin-bottom: 20px; display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end;">
        <div>
            <label>Фильтр по группе: </label><br>
            <select id="group-filter" style="padding: 5px; width: 250px;">
                <option value="">Все группы</option>
                {% for group in groups %}
                <option value="{{ group.id }}">{{ group.university_name }} / {{ group.faculty_name }} / {{ group.group_name }}</option>
                {% endfor %}
            </select>
        </div>
        
        <div>
            <label>Поиск: </label><br>
            <input type="text" id="search-homework" placeholder="Поиск по названию, предмету, группе..." style="padding: 5px; width: 250px;">
        </div>
        
        <div>
            <button id="search-btn" style="padding: 5px 15px;">🔍 Искать</button>
            <button id="reset-search-btn" style="padding: 5px 15px; display: none;">🔄 Сбросить</button>
        </div>
    </div>

    <p><button id="create-homework-btn">+ Добавить задание</button></p>

    <div style="margin-bottom: 10px;">
        <strong>Всего заданий:</strong> <span id="total-homework">0</span>
    </div>

    <table border="1" cellpadding="8" cellspacing="0" style="width: 100%; border-collapse: collapse;">
        <thead>
            <tr>
                <th>ID</th>
                <th>Название</th>
                <th>Группа</th>
                <th>Предмет</th>
                <th>Дедлайн</th>
                <th>Отправок</th>
                <th>Ср.балл по группе</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody id="homework-table-body"></tbody>
    </table>

    <div id="pagination" style="margin-top: 20px;"></div>

    <!-- Модальное окно создания/редактирования -->
    <div id="homework-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000;">
        <div style="background: white; width: 600px; margin: 50px auto; padding: 20px; border-radius: 8px; max-height: 90vh; overflow-y: auto;">
            <h3 id="homework-modal-title">Добавление задания</h3>
            <form id="homework-form" enctype="multipart/form-data">
                <input type="hidden" id="homework-id">

                <label>Группа: <span style="color: red;">*</span></label><br>
                <select id="homework-group" required style="width: 100%; padding: 5px; margin-bottom: 10px;">
                    <option value="">Выберите группу</option>
                    {% for group in groups %}
                    <option value="{{ group.id }}">{{ group.university_name }} / {{ group.faculty_name }} / {{ group.group_name }}</option>
                    {% endfor %}
                </select>

                <label>Предмет: <span style="color: red;">*</span></label><br>
                <select id="homework-subject" required style="width: 100%; padding: 5px; margin-bottom: 10px;">
                    <option value="">Выберите предмет</option>
                    {% for subject in subjects %}
                    <option value="{{ subject.id }}">{{ subject.name }}</option>
                    {% endfor %}
                </select>

                <label>Преподаватель:</label><br>
                <select id="homework-teacher" style="width: 100%; padding: 5px; margin-bottom: 10px;">
                    <option value="">Выберите преподавателя</option>
                    {% for teacher in teachers %}
                    <option value="{{ teacher.id }}">{{ teacher.last_name }} {{ teacher.name }} {{ teacher.patronymic }}</option>
                    {% endfor %}
                </select>

                <label>Название: <span style="color: red;">*</span></label><br>
                <input type="text" id="homework-title" required style="width: 100%; padding: 5px; margin-bottom: 10px;">

                <label>Описание:</label><br>
                <textarea id="homework-description" rows="4" style="width: 100%; padding: 5px; margin-bottom: 10px;"></textarea>

                <label>Дедлайн:</label><br>
                <input type="date" id="homework-deadline" style="width: 100%; padding: 5px; margin-bottom: 10px;">

                <label>Максимальный балл:</label><br>
                <input type="number" id="homework-max-score" value="100" style="width: 100%; padding: 5px; margin-bottom: 10px;">

                <label>Файл задания (PDF, DOC, DOCX, ZIP):</label><br>
                <div style="margin-bottom: 10px;">
                    <input type="file" id="homework-file" accept=".pdf,.doc,.docx,.zip" style="width: 100%; padding: 5px;">
                    <div id="current-file-info" style="display: none; margin-top: 5px; font-size: 12px; color: #666;">
                        <span id="current-file-name"></span>
                        <button type="button" id="remove-file-btn" style="margin-left: 10px; color: red; background: none; border: none; cursor: pointer;">❌ Удалить</button>
                    </div>
                    <small style="color: #999;">Поддерживаемые форматы: PDF, DOC, DOCX, ZIP. Максимальный размер: 10MB</small>
                </div>

                <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" id="close-homework-modal" style="padding: 8px 16px;">Отмена</button>
                    <button type="submit" style="padding: 8px 16px; background: #007bff; color: white; border: none;">Сохранить</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Модальное окно просмотра отправок и оценивания -->
    <div id="submissions-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000; overflow-y: auto;">
        <div style="background: white; width: 800px; margin: 30px auto; padding: 20px; border-radius: 8px;">
            <h3>Проверка работ: <span id="submissions-title"></span></h3>
            <div id="submissions-list"></div>
            <div style="margin-top: 20px; text-align: right;">
                <button id="close-submissions-modal" style="padding: 8px 16px;">Закрыть</button>
            </div>
        </div>
    </div>

    <!-- Модальное окно оценивания -->
    <div id="grade-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1001;">
        <div style="background: white; width: 450px; margin: 50px auto; padding: 20px; border-radius: 8px;">
            <h3>Оценка работы</h3>
            <form id="grade-form">
                <input type="hidden" id="grade-submission-id">
                
                <label>Студент:</label><br>
                <span id="grade-student-name" style="font-weight: bold;"></span><br><br>

                <label>Оценка (баллы):</label><br>
                <input type="number" id="grade-score" required style="width: 100%; padding: 5px;"><br><br>

                <label>Статус:</label><br>
                <select id="grade-status" style="width: 100%; padding: 5px;">
                    <option value="approved">Принято</option>
                    <option value="rejected">Отклонено</option>
                </select><br><br>

                <label>Комментарий преподавателя:</label><br>
                <textarea id="grade-comment" rows="3" style="width: 100%; padding: 5px;"></textarea><br><br>

                <div style="display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" id="close-grade-modal" style="padding: 8px 16px;">Отмена</button>
                    <button type="submit" style="padding: 8px 16px; background: #28a745; color: white; border: none;">Сохранить оценку</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Модальное окно удаления -->
    <div id="delete-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000;">
        <div style="background: white; width: 400px; margin: 50px auto; padding: 20px; border-radius: 8px;">
            <h3>Подтверждение удаления</h3>
            <p>Вы уверены, что хотите удалить задание <strong id="delete-homework-title"></strong>?</p>
            <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
                <button id="close-delete-modal">Отмена</button>
                <button id="confirm-delete" style="background: #dc3545; color: white; border: none;">Удалить</button>
            </div>
        </div>
    </div>

    <style>
        .submission-item {
            border: 1px solid #ddd;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 15px;
        }
        .submission-item.pending { background: #fff3cd; }
        .submission-item.approved { background: #d4edda; }
        .submission-item.rejected { background: #f8d7da; }
        .submission-file a { color: #007bff; text-decoration: none; }
        .grade-btn { background: #28a745; color: white; border: none; padding: 5px 10px; border-radius: 4px; cursor: pointer; }
        .grade-btn:hover { background: #218838; }
        .submission-status { font-weight: bold; }
        .status-pending { color: #856404; }
        .status-approved { color: #155724; }
        .status-rejected { color: #721c24; }
        .page-btn { padding: 5px 10px; margin: 0 3px; cursor: pointer; }
        .pagination { margin-top: 20px; text-align: center; }
        mark { background: yellow; padding: 0 3px; }
    </style>
{% endblock %}