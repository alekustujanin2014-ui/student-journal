{% extends "layouts/admin.twig" %}

{% block content %}
    <!-- Выбор группы и поиск -->
    <div style="margin-bottom: 20px; display: flex; gap: 15px; flex-wrap: wrap; align-items: flex-end;">
        <div>
            <label>Фильтр по группе: </label><br>
            <select id="group-filter" style="padding: 5px; width: 250px;">
                <option value="">Все группы</option>
                {% for group in groups %}
                <option value="{{ group.id }}">{{ group.university_name }} / {{ group.faculty_name }} / {{ group.group_name }} ({{ group.course }} курс)</option>
                {% endfor %}
            </select>
        </div>
        
        <div>
            <label>Поиск: </label><br>
            <input type="text" id="search-exam" placeholder="Поиск по предмету, группе, преподавателю..." style="padding: 5px; width: 250px;">
        </div>
        
        <div>
            <button id="search-btn" style="padding: 5px 15px;">Искать</button>
            <button id="reset-search-btn" style="padding: 5px 15px; display: none;">Сбросить</button>
        </div>
    </div>

    <p>
        <button id="create-exam-btn">+ Добавить экзамен</button>
    </p>

    <div style="margin-bottom: 10px;">
        <strong>Всего экзаменов:</strong> <span id="total-exams">{{ exams|length }}</span>
    </div>

    <table border="1" cellpadding="8" cellspacing="0" style="border-collapse: collapse; width: 100%;">
        <thead>
            <tr>
                <th>ID</th>
                <th>Группа</th>
                <th>Предмет</th>
                <th>Дата</th>
                <th>Время</th>
                <th>Тип</th>
                <th>Преподаватель</th>
                <th>Аудитория</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody id="exams-table-body">
            {% for exam in exams %}
            <tr data-id="{{ exam.id }}">
                <td>{{ exam.id }}</td>
                <td>{{ exam.group_name }}</td>
                <td>{{ exam.subject_name }}{% if exam.subject_short %} ({{ exam.subject_short }}){% endif %}</td>
                <td>{{ exam.exam_date|date('d.m.Y') }}</td>
                <td>{{ exam.exam_time ? exam.exam_time|date('H:i') : '—' }}</td>
                <td>{{ exam.exam_type == 'exam' ? 'Экзамен' : 'Зачет' }}</td>
                <td>
                    {% if exam.teacher_last_name %}
                        {{ exam.teacher_last_name }} {{ exam.teacher_name|first }}.
                        {% if exam.teacher_patronymic %}{{ exam.teacher_patronymic|first }}.{% endif %}
                    {% else %}
                        —
                    {% endif %}
                </td>
                <td>
                    {% if exam.room_number %}
                        ауд. {{ exam.room_number }}
                        {% if exam.room_building %}({{ exam.room_building }}){% endif %}
                    {% else %}
                        —
                    {% endif %}
                </td>
                <td>
                    <button class="edit-exam-btn" data-id="{{ exam.id }}">Редактировать</button>
                    <button class="delete-exam-btn" data-id="{{ exam.id }}">Удалить</button>
                </td>
            </tr>
            {% else %}
            <tr><td colspan="9">Экзамены не найдены</td><tr>
            {% endfor %}
        </tbody>
    </table>

    <div id="pagination" style="margin-top: 20px;"></div>

    <!-- Модальное окно создания/редактирования экзамена -->
    <div id="exam-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000;">
        <div style="background: white; width: 500px; margin: 50px auto; padding: 20px; border-radius: 8px;">
            <h3 id="exam-modal-title">Добавление экзамена</h3>
            <form id="exam-form">
                <input type="hidden" id="exam-id">

                <label>Группа: <span style="color: red;">*</span></label><br>
                <select id="exam-group" required style="width: 100%; padding: 5px;">
                    <option value="">Выберите группу</option>
                    {% for group in groups %}
                    <option value="{{ group.id }}">{{ group.university_name }} / {{ group.faculty_name }} / {{ group.group_name }} ({{ group.course }} курс)</option>
                    {% endfor %}
                </select><br><br>

                <label>Предмет: <span style="color: red;">*</span></label><br>
                <select id="exam-subject" required style="width: 100%; padding: 5px;">
                    <option value="">Выберите предмет</option>
                    {% for subject in subjects %}
                    <option value="{{ subject.id }}">{{ subject.name }}</option>
                    {% endfor %}
                </select><br><br>

                <label>Преподаватель:</label><br>
                <select id="exam-teacher" style="width: 100%; padding: 5px;">
                    <option value="">Выберите преподавателя</option>
                    {% for teacher in teachers %}
                    <option value="{{ teacher.id }}">{{ teacher.last_name }} {{ teacher.name }} {{ teacher.patronymic }}</option>
                    {% endfor %}
                </select><br><br>

                <label>Аудитория:</label><br>
                <select id="exam-room" style="width: 100%; padding: 5px;">
                    <option value="">Выберите аудиторию</option>
                    {% for room in rooms %}
                    <option value="{{ room.id }}">{{ room.number }} ({{ room.building|default('—') }})</option>
                    {% endfor %}
                </select><br><br>

                <label>Дата: <span style="color: red;">*</span></label><br>
                <input type="date" id="exam-date" required style="width: 100%; padding: 5px;"><br><br>

                <label>Время:</label><br>
                <input type="time" id="exam-time" style="width: 100%; padding: 5px;"><br><br>

                <label>Тип:</label><br>
                <select id="exam-type" style="width: 100%; padding: 5px;">
                    <option value="exam">Экзамен</option>
                    <option value="credit">Зачет</option>
                </select><br><br>

                <label>Описание:</label><br>
                <textarea id="exam-description" rows="3" style="width: 100%; padding: 5px;"></textarea><br><br>

                <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
                    <button type="button" id="close-exam-modal" style="padding: 8px 16px;">Отмена</button>
                    <button type="submit" style="padding: 8px 16px; background: #007bff; color: white; border: none;">Сохранить</button>
                </div>
            </form>
        </div>
    </div>

    <!-- Модальное окно удаления -->
    <div id="delete-modal" style="display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.5); z-index: 1000;">
        <div style="background: white; width: 400px; margin: 50px auto; padding: 20px; border-radius: 8px;">
            <h3>Подтверждение удаления</h3>
            <p>Вы уверены, что хотите удалить этот экзамен?</p>
            <div style="margin-top: 20px; display: flex; gap: 10px; justify-content: flex-end;">
                <button id="close-delete-modal">Отмена</button>
                <button id="confirm-delete" style="background: #dc3545; color: white; border: none;">Удалить</button>
            </div>
        </div>
    </div>
{% endblock %}