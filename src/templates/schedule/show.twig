    <div class="exams-section">
    <div class="section-header-flex">
        <div class="section-title">
            <i class="fas fa-list-ul"></i> Список экзаменов
        </div>
        <button class="refresh-btn" id="refresh-exams">
            <i class="fas fa-sync-alt"></i> Обновить содержимое
        </button>
    </div>
    <div class="table-wrapper">
        <table class="exams-table">
            <thead>
                <tr>
                    <th>Дата</th>
                    <th>Время</th>
                    <th>Предмет</th>
                    <th>Тип</th>
                    <th>Преподаватель</th>
                    <th>Аудитория</th>
                    <th>Примечание</th>
                </tr>
            </thead>
            <tbody id="exams-tbody">
                {% if exams is defined and exams|length > 0 %}
                    {% for exam in exams %}
                        <tr>
                            <td class="exam-date">{{ exam.exam_date|date('d.m.Y') }}</td>
                            <td class="exam-time">{{ exam.exam_time ? exam.exam_time|date('H:i') : '—' }}</td>
                            <td class="exam-subject">
                                <strong>{{ exam.subject_name }}</strong>
                                {% if exam.subject_short %}
                                    <span class="subject-short">({{ exam.subject_short }})</span>
                                {% endif %}
                            </td>
                            <td class="exam-type">
                                {% if exam.exam_type == 'exam' %}
                                    <span class="badge badge-exam">Экзамен</span>
                                {% else %}
                                    <span class="badge badge-credit">Зачет</span>
                                {% endif %}
                            </td>
                            <td class="exam-teacher">
                                {% if exam.teacher_last_name %}
                                    {{ exam.teacher_last_name }} 
                                    {% if exam.teacher_name %}{{ exam.teacher_name|first }}.{% endif %}
                                    {% if exam.teacher_patronymic %}{{ exam.teacher_patronymic|first }}.{% endif %}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td class="exam-room">
                                {% if exam.room_number %}
                                    ауд. {{ exam.room_number }}
                                    {% if exam.room_building %}({{ exam.room_building }}){% endif %}
                                {% else %}
                                    —
                                {% endif %}
                            </td>
                            <td class="exam-description">{{ exam.description ?: '—' }}</td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr class="empty-row">
                        <td colspan="7" style="text-align: center; padding: 40px;">
                            <div class="empty-state">
                                <i class="fas fa-calendar-times"></i>
                                <p>Нет запланированных экзаменов</p>
                            </div>
                        </td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </div>
</div>
</div>


{% endblock %}