{% extends "layouts/main.twig" %}

{% block content %}
<div class="schedule-content">
    <div class="shedule-section">
        <div class="section-header-flex">
            <div class="section-title">
                <i class="fas fa-calendar"></i> Расписание на неделю
            </div>
            <button class="refresh-btn" id="refresh-schedule">
                <i class="fas fa-sync-alt"></i> Обновить содержимое
            </button>
        </div>
        <div class="week-nav" data-current-offset="{{ current_week.offset|default(0) }}">
            <button class="week-nav-btn" id="prev-week">← Предыдущая</button>
            <span class="week-current" id="current-week">{{ current_week.start }} - {{ current_week.end }}</span>
            <button class="week-nav-btn" id="next-week">Следующая →</button>
        </div>
        <div class="table-wrapper">
            <table class="schedule-table">
                <thead>
                    <tr>
                        <th>Время</th>
                        <th>ПН</th>
                        <th>ВТ</th>
                        <th>СР</th>
                        <th>ЧТ</th>
                        <th>ПТ</th>
                        <th>СБ</th>
                    </tr>
                </thead>
                <tbody id="schedule-tbody">
                    {% set lesson_times = {
                        1: '09:00 - 10:30',
                        2: '10:45 - 12:15',
                        3: '12:30 - 14:00',
                        4: '14:15 - 15:45',
                        5: '16:00 - 17:30'
                    } %}
                    
                    {% for lesson_num in 1..5 %}
                    <tr>
                        <td class="lesson-time">{{ lesson_times[lesson_num] }}</td>
                        {% for day in 1..6 %}
                            <td>
                                {% set lesson_found = false %}
                                {% if schedule[day] is defined %}
                                    {% for item in schedule[day] %}
                                        {% if item.lesson_number == lesson_num and not lesson_found %}
                                            {% set lesson_found = true %}
                                            <div class="lesson-name">{{ item.subject_name }}</div>
                                            {% if item.teacher_name %}
                                                <div class="lesson-teacher">{{ item.teacher_last_name }} {{ item.teacher_name|slice(0,1) }}.</div>
                                            {% endif %}
                                            {% if item.room_number %}
                                                <div class="lesson-room">ауд. {{ item.room_number }}</div>
                                            {% endif %}
                                        {% endif %}
                                    {% endfor %}
                                {% endif %}
                                {% if not lesson_found %}—{% endif %}
                            </td>
                        {% endfor %}
                    </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
        
    </div>
